{
  "name": "whatsapp-mcp",
  "version": "0.1.0",
  "description": "A Baileys-based WhatsApp MCP server: a persistent connection + local store exposing read/list/search/send tools. Browser-free alternative to scraping WhatsApp Web.",
  "type": "module",
  "bin": {
    "whatsapp-mcp": "src/server.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "pair": "node src/pair.mjs",
    "daemon": "node src/daemon.mjs",
    "mcp": "node src/server.mjs",
    "lint": "for f in src/*.mjs tools/*.mjs; do [ -e \"$f\" ] && { node --check \"$f\" || exit 1; }; done; true",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "author": "",
  "license": "AGPL-3.0-or-later",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@whiskeysockets/baileys": "^6.7.0",
    "better-sqlite3": "^12.11.1",
    "pino": "^10.3.1",
    "qrcode-terminal": "^0.12.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "prettier": "^3.9.0"
  }
}
